server default {
  listen {
    type = control
    socket = ${run_dir}/${name}.sock
    mode = rw
  }
  listen {
    type = auth
    ipaddr = *
    port = 1812
    limit {
      max_connections = 16
      lifetime = 0
      idle_timeout = 900
    }
  }
  listen {
    type = acct
    ipaddr = *
    port = 1813
    limit {
    }
  }
  authorize {
    preprocess
    eap
    files
  }
  authenticate {
    eap
  }
  preacct {
    preprocess
    acct_unique
    suffix
    files
  }
  accounting {
    detail
    -sql
    exec
    attr_filter.accounting_response
    radutmp
  }
  session {
  }
  post-auth {
    if (session-state:User-Name && reply:User-Name && request:User-Name && (reply:User-Name == request:User-Name)) {
      update reply {
        &User-Name !* ANY
      }
    }
    update {
      &reply: += &session-state:
    }
    -sql
    exec
    remove_reply_message_if_eap
    Post-Auth-Type REJECT {
      -sql
      attr_filter.access_reject
      eap
      remove_reply_message_if_eap
    }
    Post-Auth-Type Challenge {
    }
    Post-Auth-Type Client-Lost {
    }
    if (EAP-Key-Name && &reply:EAP-Session-Id) {
      update reply {
        &EAP-Key-Name := &reply:EAP-Session-Id
      }
    }
  }
  pre-proxy {
  }
  post-proxy {
  }
}