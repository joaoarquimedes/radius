eap {
  # Valor defautl md5. Alterado para peap
  default_eap_type = peap
  timer_expire = 60
  ignore_unknown_eap_types = no
  cisco_accounting_username_bug = no
  max_sessions = ${max_requests}
  tls-config tls-common {
    private_key_file = ${certdir}/server.key
    certificate_file = ${certdir}/server.pem
    ca_file = ${cadir}/ca.pem

    private_key_password = whatever

    # Versões de TLS permitidas
    tls_min_version = "1.2"
    tls_max_version = "1.3"

    # Desabilita protocolos antigos implicitamente
    disable_tlsv1 = yes
    disable_tlsv1_1 = yes

    # Ciphers seguros
    cipher_list = "HIGH:!aNULL:!eNULL:!MD5:!RC4:!3DES"

    # Curvas modernas
    ecdh_curve = "prime256v1"

    # Verificação de cliente (opcional dependendo do cenário)
    verify {
      tmpdir = /tmp/
    }
    cache {
      enable = yes
      lifetime = 24 # horas
      max_entries = 255
    }
  }
  peap {
    tls = tls-common
    default_eap_type = mschapv2
    copy_request_to_tunnel = no
    use_tunneled_reply = no
    virtual_server = "inner-tunnel"
  }
  mschapv2 {
  }
}